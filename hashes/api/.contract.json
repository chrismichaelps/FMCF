      "encoded_via": "Schema.encode(AuthResponse)"
    }
  ],
  "error_http_map": {
    "ValidationError": 400,
    "DuplicateEmailError": 409,
    "InvalidCredentialsError": 401,
    "DbConnectionError": 503
